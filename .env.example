# Window Cleaning Engine — environment template
# Copy to `.env` and fill in real values. Do NOT commit `.env` itself.
# `.env` is git-ignored. See DEPLOYMENT.md for what each variable does.

# ---------------------------------------------------------------------------
# Required for production
# ---------------------------------------------------------------------------

# Flask session signing key. MUST be a long random string in production —
# anything else makes session cookies forgeable. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
# The default in config.py ("sre_secret_key_change_me_in_prod") is intentionally
# insecure so a forgotten env var fails the pre-flight check rather than
# silently shipping a vulnerable deploy.
SRE_SECRET_KEY=

# ---------------------------------------------------------------------------
# Stripe — live billing
# ---------------------------------------------------------------------------
# Sprint 4 ships with these unset (test-mode operation). Sprint 5 swaps in
# live keys (sk_live_..., pk_live_..., whsec_... from the live-mode webhook).
# When STRIPE_SECRET_KEY is unset, /checkout returns a 503 explaining Stripe
# is not configured, and /dev/grant-credits is reachable if DEV_MODE=1.

STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Externally-resolvable base URL. Stripe uses this to build success_url /
# cancel_url for Checkout sessions, so misconfiguring it sends customers
# back to localhost after paying. Must include scheme and no trailing slash.
APP_BASE_URL=https://example.com

# ---------------------------------------------------------------------------
# Dev-mode escape hatches (do NOT set in production)
# ---------------------------------------------------------------------------
# DEV_MODE=1 enables three things at once, all of which must be off in prod:
#   1. /dev/grant-credits simulator (also requires STRIPE_SECRET_KEY unset)
#   2. SESSION_COOKIE_SECURE turned off (so plain-HTTP localhost works)
#   3. Talisman force_https + HSTS turned off (same reason)
# Hard-gated where possible (the simulator route 404s if real Stripe keys
# are present), but the cookie/HTTPS gates only check DEV_MODE itself.
# Leave UNSET in production.
DEV_MODE=

# Hotfix-2 test-only kill switches. Both NEVER set in production.
# WTF_CSRF_DISABLED=1 turns off Flask-WTF CSRF token enforcement so the
# existing stress_probe + locust harness can POST forms without grabbing
# tokens. RATELIMIT_DISABLED=1 turns off Flask-Limiter so locust can
# hammer auth routes without tripping the per-IP gate.
WTF_CSRF_DISABLED=
RATELIMIT_DISABLED=

# ---------------------------------------------------------------------------
# Optional tunables
# ---------------------------------------------------------------------------

# Free-tier rate limit per rolling 60-min window. Active subscribers exempt.
RATE_LIMIT_QUOTES_PER_HOUR=10

# Annual subscriber soft-cap notice threshold (per billing period).
# - At 80% of this number, /generate attaches `soft_cap_warning` (no CTA).
# - At 100%+, /generate attaches `soft_cap_notice` (full CTA pointing to
#   the in-app /contact form for a custom-plan conversation).
# Generation is never throttled by this — it's purely informational.
SOFT_CAP_THRESHOLD=1000

# Public-facing support address. Surfaced in the contact CTA and the
# site-wide footer (Sprint 4 T5). Configurable per-environment so test /
# staging / prod can route conversations to different inboxes.
SUPPORT_EMAIL=support@example.com
